{
  "name": "simple-browser",
  "version": "0.0.2",
  "files": [
    "./src/",
    "./run"
  ],
  "bin": {
    "browser": "run"
  },
  "scripts": {
    "main": "tsc && electron ./build/main.js",
    "dev": "npx --yes nodemon@latest --watch src --ext ts --exec 'NODE_ENV=development npm run main'",
    "start": "NODE_ENV=production npm run main"
  },
  "devDependencies": {
    "@types/node": "^24.9.2",
    "electron": "^39.0.0",
    "typescript": "^5.9.3"
  }
}
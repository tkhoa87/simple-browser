{
  "name": "simple-browser",
  "version": "0.0.10",
  "type": "module",
  "files": [
    "./build/",
    "./run"
  ],
  "bin": {
    "simple-browser": "run",
    "browser": "run"
  },
  "scripts": {
    "main": "electron ./build/main.js",
    "dev": "npx --yes nodemon@latest --watch src --ext ts --exec 'tsc && NODE_ENV=development npm run main'",
    "start": "NODE_ENV=production npm run main",
    "prepublish": "tsc"
  },
  "dependencies": {
    "electron": "^39.1.2",
    "find-free-ports": "^3.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "typescript": "^5.9.3"
  }
}
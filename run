#!/usr/bin/env bash

# Environment Flags
set -o errexit  # Exit when a command fails
set -o pipefail # Catch mysqldump fails
set -o nounset  # Exit when using undeclared variables

# Usage function following UNIX standard
usage() {
  cat << EOF

Usage: $(basename "$0") [OPTIONS] [URL]
       $(basename "$0") COMMAND

COMMANDS:
  start    Start the simple-browser process using PM2
  stop     Stop and remove the simple-browser process from PM2

OPTIONS:
  -h, --help                     Show this help message and exit
  -b, --browser BROWSER          Browser to use: electron (default) or chrome
  --remote-debugging-port PORT   Set remote debugging port (highest priority)
  --port PORT                    Set remote debugging port (alias)
  -p PORT                        Set remote debugging port (short alias)
  --<chromium-switch>[=VALUE]    Pass switch to Chromium (e.g., --disable-gpu)

ENVIRONMENT:
  REMOTE_DEBUGGING_PORT   Default port if not specified via CLI (default: 9222)

EXAMPLES:
  $(basename "$0") https://example.com
  $(basename "$0") --port 9333 https://example.com
  $(basename "$0") --disable-gpu --proxy-server=http://proxy:8080 https://example.com
  $(basename "$0") start
  $(basename "$0") stop
  $(basename "$0") start --port 9333
  $(basename "$0") stop --port 9333
  $(basename "$0") -b chrome https://example.com
  $(basename "$0") -b chrome --port 9333 https://example.com
  $(basename "$0") start -b chrome
  $(basename "$0") stop -b chrome

EOF
}

# Find Chrome binary
find_chrome() {
  # Check for google-chrome command (Linux)
  if command -v google-chrome &> /dev/null; then
    echo "google-chrome"
    return 0
  fi
  # Check for chromium command (Linux alternative)
  if command -v chromium &> /dev/null; then
    echo "chromium"
    return 0
  fi
  # Check for Chrome in Applications (macOS)
  if [[ -d "/Applications/Google Chrome.app" ]]; then
    echo "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
    return 0
  fi
  # Check for Chromium in Applications (macOS)
  if [[ -d "/Applications/Chromium.app" ]]; then
    echo "/Applications/Chromium.app/Contents/MacOS/Chromium"
    return 0
  fi
  return 1
}

# Extract browser option from arguments and return remaining args
# Sets global variables: BROWSER, REMAINING_ARGS
parse_browser_option() {
  BROWSER="electron"  # exported for use by caller
  REMAINING_ARGS=()   # exported for use by caller
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -b|--browser)
        if [[ -n "${2:-}" ]]; then
          BROWSER="$2"
          shift 2
        else
          echo "Error: -b/--browser requires a value (electron or chrome)" >&2
          exit 1
        fi
        ;;
      -b=*|--browser=*)
        BROWSER="${1#*=}"
        shift
        ;;
      *)
        REMAINING_ARGS+=("$1")
        shift
        ;;
    esac
  done
}

# Check if PM2 process exists (any state)
pm2_process_exists() {
  local NAME="$1"
  npx --yes pm2@latest describe "$NAME" &>/dev/null
}

# Check if PM2 process is online
pm2_process_online() {
  local NAME="$1"
  local STATUS
  STATUS=$(npx --yes pm2@latest jlist 2>/dev/null | python3 -c "
import sys, json
procs = json.load(sys.stdin)
for p in procs:
    if p.get('name') == '$NAME':
        print(p.get('pm2_env', {}).get('status', ''))
        break
" 2>/dev/null || true)
  [[ "$STATUS" == "online" ]]
}

# Acquire a filesystem lock (mkdir is atomic on all UNIX systems)
acquire_lock() {
  local LOCKDIR="$1"
  local MAX_WAIT=30
  local WAITED=0
  while ! mkdir "$LOCKDIR" 2>/dev/null; do
    # Check for stale lock (older than 60s)
    if [[ -d "$LOCKDIR" ]]; then
      local LOCK_AGE
      LOCK_AGE=$(( $(date +%s) - $(stat -f %m "$LOCKDIR" 2>/dev/null || stat -c %Y "$LOCKDIR" 2>/dev/null || echo 0) ))
      if [[ $LOCK_AGE -gt 60 ]]; then
        echo "Removing stale lock (${LOCK_AGE}s old)." >&2
        rmdir "$LOCKDIR" 2>/dev/null || rm -rf "$LOCKDIR"
        continue
      fi
    fi
    if [[ $WAITED -ge $MAX_WAIT ]]; then
      echo "Warning: Lock timeout after ${MAX_WAIT}s. Breaking lock." >&2
      rmdir "$LOCKDIR" 2>/dev/null || rm -rf "$LOCKDIR"
      continue
    fi
    sleep 1
    WAITED=$((WAITED + 1))
  done
}

release_lock() {
  rmdir "$1" 2>/dev/null || true
}

# Handle occupied port with CDP-aware logic
# Returns 0 if we should start our browser, 1 if we should exit (existing browser handles it)
handle_occupied_port() {
  local PORT="$1"
  local PID
  PID=$(lsof -ti ":${PORT}" 2>/dev/null || true)
  if [[ -z "$PID" ]]; then
    return 0
  fi

  echo "Port ${PORT} is occupied (PID: ${PID}). Checking if it's a CDP endpoint..."

  # Check if it's a CDP endpoint
  local CDP_RESPONSE
  CDP_RESPONSE=$(curl -s --max-time 3 "http://localhost:${PORT}/json/version" 2>/dev/null || true)

  if [[ -z "$CDP_RESPONSE" ]] || ! echo "$CDP_RESPONSE" | python3 -c "import sys,json; json.load(sys.stdin)" 2>/dev/null; then
    echo "Not a CDP endpoint. Killing process on port ${PORT} (PID: ${PID})..."
    kill -9 $PID 2>/dev/null || true
    sleep 0.5
    return 0
  fi

  echo "CDP endpoint detected."

  # Check for open tabs
  local TAB_COUNT
  TAB_COUNT=$(curl -s --max-time 3 "http://localhost:${PORT}/json/list" 2>/dev/null | python3 -c "
import sys, json
try:
    tabs = json.load(sys.stdin)
    pages = [t for t in tabs if t.get('type') == 'page']
    print(len(pages))
except:
    print(0)
" 2>/dev/null || echo "0")

  if [[ "$TAB_COUNT" -eq 0 ]]; then
    echo "No tabs open. Opening a new tab..."
    curl -s --max-time 3 "http://localhost:${PORT}/json/new" >/dev/null 2>&1 || true
    echo "New tab opened on existing browser (port ${PORT}). Exiting."
    return 1
  else
    echo "Browser already has ${TAB_COUNT} tab(s) open on port ${PORT}. Exiting."
    return 1
  fi
}

# Start Chrome with remote debugging
start_chrome() {
  local PORT="${1:-${REMOTE_DEBUGGING_PORT:-9222}}"
  local USER_DATA_DIR="/tmp/simple-browser-${PORT}"
  shift || true
  local CHROME_BIN
  CHROME_BIN=$(find_chrome) || {
    echo "Error: Chrome not found. Install Google Chrome or Chromium." >&2
    exit 1
  }

  if ! handle_occupied_port "$PORT"; then
    exit 0
  fi
  echo "Starting Chrome with remote debugging on port ${PORT}..."
  echo "Chrome binary: ${CHROME_BIN}"
  echo

  # Build Chrome arguments
  local CHROME_ARGS=(
    "--remote-debugging-port=${PORT}"
    "--user-data-dir=${USER_DATA_DIR}"
    "--no-first-run"
    "--no-default-browser-check"
    "--start-maximized"
  )

  # Add user-provided arguments
  for arg in "$@"; do
    CHROME_ARGS+=("$arg")
  done

  exec "$CHROME_BIN" "${CHROME_ARGS[@]}"
}

# Handle --help flag
if [[ "${1:-}" == "--help" ]] || [[ "${1:-}" == "-h" ]]; then
  usage
  exit 0
fi

FOLDER="$(readlink -f "${BASH_SOURCE[0]}" | xargs dirname)"
cd "${FOLDER}" || exit 1

if [[ "${1:-}" == "start" ]] || [[ "${1:-}" == "stop" ]]; then

  COMMAND="${1}"
  shift

  case "${COMMAND}" in

    start)
      # Parse browser option
      parse_browser_option "$@"
      set -- "${REMAINING_ARGS[@]+"${REMAINING_ARGS[@]}"}"

      # Extract port from arguments
      PORT=""
      for arg in "$@"; do
        case "$arg" in
          --port=*|--remote-debugging-port=*|-p=*)
            PORT="${arg#*=}"
            ;;
        esac
      done
      # Check for space-separated port value
      if [[ -z "$PORT" ]]; then
        TEMP_ARGS=("$@")
        for ((i=0; i<${#TEMP_ARGS[@]}; i++)); do
          case "${TEMP_ARGS[i]}" in
            --port|--remote-debugging-port|-p)
              PORT="${TEMP_ARGS[i+1]:-}"
              break
              ;;
          esac
        done
      fi

      if [[ "$BROWSER" == "chrome" ]]; then
        PORT="${PORT:-${REMOTE_DEBUGGING_PORT:-9222}}"
        NAME="simple-browser-${PORT}"

        LOCKDIR="/tmp/simple-browser-${NAME}.lock"
        acquire_lock "$LOCKDIR"
        trap "release_lock '$LOCKDIR'" EXIT

        # Check if process already exists in PM2 (inside lock to prevent races)
        if pm2_process_exists "$NAME"; then
          if pm2_process_online "$NAME"; then
            echo
            echo "${NAME} already running in PM2. Skipping start."
            release_lock "$LOCKDIR"
            exit 0
          else
            echo
            echo "${NAME} exists but is not running. Restarting..."
            npx --yes pm2@latest delete "$NAME" 2>/dev/null || true
          fi
        fi

        CHROME_BIN=$(find_chrome) || {
          release_lock "$LOCKDIR"
          echo "Error: Chrome not found. Install Google Chrome or Chromium." >&2
          exit 1
        }

        if ! handle_occupied_port "$PORT"; then
          release_lock "$LOCKDIR"
          exit 0
        fi

        # Filter out port arguments from remaining args for Chrome
        CHROME_USER_ARGS=()
        SKIP_NEXT=false
        for arg in "$@"; do
          if [[ "$SKIP_NEXT" == "true" ]]; then
            SKIP_NEXT=false
            continue
          fi
          case "$arg" in
            --port=*|--remote-debugging-port=*|-p=*)
              continue
              ;;
            --port|--remote-debugging-port|-p)
              SKIP_NEXT=true
              continue
              ;;
            *)
              CHROME_USER_ARGS+=("$arg")
              ;;
          esac
        done

        # Build Chrome command
        USER_DATA_DIR="/tmp/simple-browser-${PORT}"
        CHROME_CMD="\"${CHROME_BIN}\" --remote-debugging-port=${PORT} --user-data-dir=${USER_DATA_DIR} --no-first-run --no-default-browser-check --start-maximized"

        # Add user args
        for arg in "${CHROME_USER_ARGS[@]+"${CHROME_USER_ARGS[@]}"}"; do
          CHROME_CMD+=" \"$arg\""
        done

        echo
        echo "Starting ${NAME}..."
        npx --yes pm2@latest start --no-autorestart -i 1 --name "$NAME" "$CHROME_CMD"
        echo
        echo "${NAME} started"
        release_lock "$LOCKDIR"
      else
        PORT="${PORT:-9222}"
        NAME="simple-browser-${PORT}"

        LOCKDIR="/tmp/simple-browser-${NAME}.lock"
        acquire_lock "$LOCKDIR"
        trap "release_lock '$LOCKDIR'" EXIT

        # Check if process already exists in PM2 (inside lock to prevent races)
        if pm2_process_exists "$NAME"; then
          if pm2_process_online "$NAME"; then
            echo
            echo "${NAME} already running in PM2. Skipping start."
            release_lock "$LOCKDIR"
            exit 0
          else
            echo
            echo "${NAME} exists but is not running. Restarting..."
            npx --yes pm2@latest delete "$NAME" 2>/dev/null || true
          fi
        fi

        # Build args string without browser option
        ARGS=""
        for arg in "$@"; do
          ARGS+=" \"$arg\""
        done

        echo
        echo "Starting ${NAME}..."
        npx --yes pm2@latest start --no-autorestart -i 1 --name "$NAME" "npx --yes simple-browser@latest${ARGS}"
        echo
        echo "${NAME} started"
        release_lock "$LOCKDIR"
      fi
      ;;

    stop)
      # Parse browser option
      parse_browser_option "$@"
      set -- "${REMAINING_ARGS[@]+"${REMAINING_ARGS[@]}"}"

      # Extract port from arguments
      PORT=""
      for arg in "$@"; do
        case "$arg" in
          --port=*|--remote-debugging-port=*|-p=*)
            PORT="${arg#*=}"
            ;;
        esac
      done
      # Check for space-separated port value
      if [[ -z "$PORT" ]]; then
        TEMP_ARGS=("$@")
        for ((i=0; i<${#TEMP_ARGS[@]}; i++)); do
          case "${TEMP_ARGS[i]}" in
            --port|--remote-debugging-port|-p)
              PORT="${TEMP_ARGS[i+1]:-}"
              break
              ;;
          esac
        done
      fi

      if [[ "$BROWSER" == "chrome" ]]; then
        PORT="${PORT:-${REMOTE_DEBUGGING_PORT:-9222}}"
        NAME="simple-browser-${PORT}"
      else
        PORT="${PORT:-9222}"
        NAME="simple-browser-${PORT}"
      fi

      echo
      echo "Stopping ${NAME}..."
      npx --yes pm2@latest delete "$NAME" || true
      echo
      echo "${NAME} stopped"
      ;;

  esac

else

  # Parse browser option for direct execution
  parse_browser_option "$@"
  set -- "${REMAINING_ARGS[@]+"${REMAINING_ARGS[@]}"}"

  usage

  export DISPLAY="${DISPLAY:-:0}"

  if [[ "$BROWSER" == "chrome" ]]; then
    # Extract port from arguments for Chrome
    PORT=""
    for arg in "$@"; do
      case "$arg" in
        --port=*|--remote-debugging-port=*|-p=*)
          PORT="${arg#*=}"
          ;;
      esac
    done
    if [[ -z "$PORT" ]]; then
      TEMP_ARGS=("$@")
      for ((i=0; i<${#TEMP_ARGS[@]}; i++)); do
        case "${TEMP_ARGS[i]}" in
          --port|--remote-debugging-port|-p)
            PORT="${TEMP_ARGS[i+1]:-}"
            break
            ;;
        esac
      done
    fi
    PORT="${PORT:-${REMOTE_DEBUGGING_PORT:-9222}}"

    # Filter out port arguments
    CHROME_USER_ARGS=()
    SKIP_NEXT=false
    for arg in "$@"; do
      if [[ "$SKIP_NEXT" == "true" ]]; then
        SKIP_NEXT=false
        continue
      fi
      case "$arg" in
        --port=*|--remote-debugging-port=*|-p=*)
          continue
          ;;
        --port|--remote-debugging-port|-p)
          SKIP_NEXT=true
          continue
          ;;
        *)
          CHROME_USER_ARGS+=("$arg")
          ;;
      esac
    done

    echo
    start_chrome "$PORT" "${CHROME_USER_ARGS[@]+"${CHROME_USER_ARGS[@]}"}"
  else
    (
      echo
      npm start -- -- "$@"
    )
  fi

fi
